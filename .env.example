# FlipLedger environment variables.
# Most credentials are stored in the SQLite settings table (entered via the
# Settings page on first run), so this file is mostly here for the optional
# overrides below. Copy to `.env.local` if you want to use any of these.

# Override the default port (default: 3000)
# PORT=3000

# Override the default DB path (default: ./data/flipledger.db)
# FLIPLEDGER_DB_PATH=./data/flipledger.db

# ── Marketplace credentials ─────────────────────────────────────────────────
# These can be entered on the Settings page after first launch — you do NOT
# need to put them here. Listed for completeness if you prefer env-based config.

# Amazon SP-API (LWA OAuth) — register at https://developer-docs.amazon.com/sp-api
# AMAZON_CLIENT_ID=
# AMAZON_CLIENT_SECRET=
# AMAZON_REFRESH_TOKEN=
# AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER

# Walmart Marketplace API — register at https://developer.walmart.com
# WALMART_CLIENT_ID=
# WALMART_CLIENT_SECRET=

# eBay API — register at https://developer.ebay.com
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_REFRESH_TOKEN=
